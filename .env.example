# ============================================================
# BizRithm Environment Configuration — Example
# Copy this to .env and fill in your values
# ============================================================

# ── Application ────────────────────────────────────────────
APP_NAME=BizRithm
APP_VERSION=1.0.0
APP_ENV=development
DEBUG=true
SECRET_KEY=your-super-secret-key-change-this-in-production
ALLOWED_ORIGINS=http://localhost:8501,http://localhost:3000

# ── Database ───────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://bizrithm:bizrithm123@localhost:5432/bizrithm_db
DATABASE_URL_SYNC=postgresql://bizrithm:bizrithm123@localhost:5432/bizrithm_db
DB_HOST=localhost
DB_PORT=5432
DB_NAME=bizrithm_db
DB_USER=bizrithm
DB_PASSWORD=bizrithm123

# ── Redis Cache ────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0
REDIS_PASSWORD=

# ── AI API Keys ────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here
OPENAI_API_KEY=your-openai-api-key-here
DEFAULT_LLM_PROVIDER=gemini
GEMINI_MODEL=gemini-1.5-flash
OPENAI_MODEL=gpt-4o-mini

# ── JWT Authentication ─────────────────────────────────────
JWT_SECRET_KEY=your-jwt-secret-change-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30

# ── File Storage ───────────────────────────────────────────
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=100
ALLOWED_EXTENSIONS=csv,xlsx,xls,json

# ── Reports ────────────────────────────────────────────────
REPORTS_DIR=./reports/generated
CHARTS_DIR=./reports/charts

# ── ML Models ─────────────────────────────────────────────
ML_MODELS_DIR=./ml_models/saved
ENABLE_LSTM=false
DEFAULT_FORECAST_PERIODS=30

# ── Email Alerts (Advanced) ────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASSWORD=your-app-password
EMAIL_FROM=noreply@bizrithm.ai

# ── Logging ────────────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FILE=./logs/bizrithm.log

# ── Rate Limiting ──────────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
RATE_LIMIT_BURST=10
